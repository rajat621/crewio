# =============================================================================
# AI Service Environment Configuration
# =============================================================================

# ---------------------------------------------------------------------------
# Vision (Gemini) — PRIMARY engine for scanned/image PDFs
# Set this to enable Gemini Vision. Without it, OCR fallback is used instead.
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here        # alternative key name

VISION_MODEL=gemini-2.5-flash
VISION_MAX_PAGES=10
VISION_TIMEOUT_S=120

# ---------------------------------------------------------------------------
# OCR — FINAL FALLBACK only (runs only when Vision fails)
# ---------------------------------------------------------------------------
ENABLE_PADDLE_OCR=true
OCR_RASTER_DPI=250
OCR_TARGET_LONG_EDGE=2200

# ---------------------------------------------------------------------------
# Extraction pipeline
# ---------------------------------------------------------------------------
# digital = use native pdfplumber; threshold below triggers routing to Vision
DIGITAL_CHAR_THRESHOLD=80
DIGITAL_PAGE_RATIO=0.6

# Semantic confidence threshold before skipping Vision
SEMANTIC_CONFIDENCE_THRESHOLD=0.6

# ---------------------------------------------------------------------------
# LLM (Ollama) — semantic normalization overlay, optional
# ---------------------------------------------------------------------------
ENABLE_OLLAMA=false
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
ENABLE_SEMANTIC_EXTRACTION=false

# ---------------------------------------------------------------------------
# Timeouts (milliseconds)
# ---------------------------------------------------------------------------
OCR_TIMEOUT_MS=300000
TABLE_EXTRACTION_TIMEOUT_MS=300000
PROVIDER_TIMEOUT_MS=300000
AI_JOB_TIMEOUT_MS=300000
AI_SERVICE_TIMEOUT_MS=300000

# ---------------------------------------------------------------------------
# Resource limits
# ---------------------------------------------------------------------------
MAX_PDF_PAGES=15
MAX_PAYLOAD_MB=50
MAX_OCR_IMAGES=10
MAX_SEMANTIC_TOKENS=4096
VISION_MAX_PAGES=10

# ---------------------------------------------------------------------------
# Concurrency
# ---------------------------------------------------------------------------
AI_WORKER_CONCURRENCY=2
OCR_CONCURRENCY=2
SEMANTIC_CONCURRENCY=1
PDF_CONCURRENCY=2
INFERENCE_CONCURRENCY=1

# ---------------------------------------------------------------------------
# Queue
# ---------------------------------------------------------------------------
QUEUE_BACKOFF_DELAY_MS=5000
QUEUE_ATTEMPTS=3
WORKER_RETRIES=3

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
TRACING_ENABLED=true
METRICS_ENABLED=true
STRUCTURED_LOGS_ENABLED=true
LOG_VERBOSITY=info

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=8001

# ---------------------------------------------------------------------------
# Debug (set to true to dump debug artifacts)
# ---------------------------------------------------------------------------
AI_EXTRACT_DEBUG=false
AI_EXTRACT_DEBUG_DIR=storage/debug
